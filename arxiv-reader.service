[Unit]
Description=arxiv-reader daily pipeline
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ken
WorkingDirectory=/home/ken/arxiv-reader/backend
ExecStart=/home/ken/miniconda3/envs/torch/bin/python main.py
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
